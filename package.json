{
  "name": "code-school",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "node --test",
    "db:generate": "prisma generate",
    "format": "prettier --write \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"content/**/*.{mdx,json}\" \"db/**/*.{ts,tsx,md}\" \"lib/**/*.{ts,tsx}\" \"prisma/**/*.{prisma,sql}\" \"tests/**/*.{ts,tsx,mts}\" \"*.{json,md,ts}\"",
    "format:check": "prettier --check \"app/**/*.{ts,tsx,css}\" \"components/**/*.{ts,tsx}\" \"content/**/*.{mdx,json}\" \"db/**/*.{ts,tsx,md}\" \"lib/**/*.{ts,tsx}\" \"prisma/**/*.{prisma,sql}\" \"tests/**/*.{ts,tsx,mts}\" \"*.{json,md,ts}\""
  },
  "dependencies": {
    "@prisma/client": "^6.6.0",
    "gray-matter": "^4.0.3",
    "next": "^15.3.0",
    "next-mdx-remote": "^5.0.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.1",
    "@types/node": "^22.14.1",
    "@types/react": "^19.0.12",
    "@types/react-dom": "^19.0.4",
    "eslint": "^9.24.0",
    "eslint-config-next": "^15.3.0",
    "prettier": "^3.5.3",
    "prisma": "^6.6.0",
    "typescript": "^5.8.3"
  }
}
